{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "personal-website",
	"compatibility_date": "2025-06-06",
	"assets": {
		"directory": "./public"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "www.sapir.io",
			"custom_domain": true
		},
		{
			"pattern": "sapir.io",
			"custom_domain": true
		}
	]
}
